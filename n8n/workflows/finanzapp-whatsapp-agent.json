    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst base64Data = response.base64;\nconst mimeType = response.mimetype || 'audio/ogg; codecs=opus';\nconst datosOriginales = $('Extraer Datos Mensaje').first().json;\n\nreturn [{\n  json: {\n    telefono: datosOriginales.telefono,\n    remoteJid: datosOriginales.remoteJid,\n    contacto: datosOriginales.contacto,\n    messageId: datosOriginales.messageId,\n  },\n  binary: {\n    data: {\n      data: base64Data,\n      mimeType: mimeType,\n      fileName: 'audio.ogg',\n    }\n  }\n}];"
      },
