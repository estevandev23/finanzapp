# =============================================================
# .env.example — Variables de entorno para docker-compose.yml
# =============================================================
# Copia este archivo como .env y ajusta los valores antes de
# ejecutar docker compose up -d --build
# =============================================================

# ── Base de datos ─────────────────────────────────────────────
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_PORT=5432

# ── Backend (finanzapp-api) ───────────────────────────────────
API_PORT=8080

# Secreto JWT — cámbialo en producción (mínimo 256 bits)
JWT_SECRET=MiClaveSecretaParaJWTQueTieneAlMenos256BitsDeSeguridad2024FinanzApp
JWT_EXPIRATION=86400000          # 24 horas en ms
JWT_REFRESH_EXPIRATION=604800000 # 7 días en ms

# Hibernate
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false

# Logging
LOG_LEVEL=INFO

# JVM (ajustar según recursos disponibles)
JAVA_OPTS=-Xms256m -Xmx512m

# ── MCP Server (finanzapp-mcp) ────────────────────────────────
# URL del backend que verá el MCP (nombre del servicio Docker)
FINANZAPP_API_URL=http://finanzapp-api:8080/api/v1

# Token JWT — Solo necesario para uso directo del MCP (Claude Desktop).
# En el flujo WhatsApp/n8n la autenticacion se gestiona automaticamente
# mediante sesiones en la base de datos (no se requiere este token).
FINANZAPP_JWT_TOKEN=

# Timeout de peticiones al backend en milisegundos
FINANZAPP_TIMEOUT=30000

# ── N8N — Motor de automatización ────────────────────────────
N8N_PORT=5678

# Clave de cifrado para credenciales guardadas en N8N.
# Genera una clave aleatoria con: openssl rand -hex 32
N8N_ENCRYPTION_KEY=cambiar-esto-en-produccion-256bits

# URL pública del servidor N8N para que Evolution API alcance
# los webhooks. En desarrollo local, usa ngrok:
#   ngrok http 5678  → copia la URL https://xxxx.ngrok.io aquí
N8N_WEBHOOK_URL=https://TU-DOMINIO-O-NGROK.ngrok.io

# ── WhatsApp (Evolution API) ──────────────────────────────────
# URL donde esta corriendo tu instancia de Evolution API.
# Si Evolution API corre en un docker-compose separado, usa la
# IP del host o el nombre del contenedor segun la red Docker.
#
# Opciones comunes:
#   http://evolution-api:8080  (si estan en la misma red Docker)
#   http://host.docker.internal:8080  (Docker Desktop Windows/Mac)
#   http://localhost:8080  (si n8n corre fuera de Docker)
EVOLUTION_API_URL=http://host.docker.internal:8080

# API Key de tu Evolution API (la configuraste al instalar Evolution)
EVOLUTION_API_KEY=

# Nombre de la instancia de WhatsApp que creaste en Evolution API
EVOLUTION_INSTANCE_NAME=finanzapp

# ── IA — Anthropic Claude ─────────────────────────────────────
# Clave de API de Anthropic para usar Claude como agente de IA.
# Obténla en: https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── OAuth Providers ───────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
NEXTAUTH_SECRET=cambiar-esto-en-produccion

# ── Email SMTP (Gmail) ───────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=finanzapp@gmail.com

# ── Twilio SMS ────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

